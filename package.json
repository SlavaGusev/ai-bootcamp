{
  "name": "auth-service",
  "version": "1.0.0",
  "description": "Educational AuthService for QA automation training with AI agents",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
    "init-db": "ts-node src/init_db.ts",
    "break-user": "ts-node src/break_user.ts",
    "restore-user": "ts-node src/restore_user.ts",
    "test": "playwright test",
    "test:ci": "playwright test --reporter=line",
    "test:logs:mcp": "playwright test -c playwright.logs.config.ts tests/specs/logs-mcp.spec.ts --reporter=line",
    "test:server": "node tests/scripts/start-server.js",
    "test:docker": "docker compose --profile test run --rm auth-service-tests",
    "mcp:logs": "node dist/mcp/logs-server.js",
    "mcp:logs:dev": "ts-node src/mcp/logs-server.ts"
  },
  "keywords": [
    "auth",
    "educational",
    "QA",
    "automation"
  ],
  "author": "QA Training Team",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.19.1",
    "express": "^4.18.2",
    "pino": "^8.16.1",
    "pino-pretty": "^10.2.0",
    "sqlite3": "^5.1.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.2",
    "@types/express": "^4.17.17",
    "@types/node": "^20.3.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.3"
  }
}
